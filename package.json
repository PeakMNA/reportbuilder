{
  "name": "reportbuilder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3008",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=__tests__",
    "test:integration": "jest --testPathPatterns=integration",
    "test:e2e": "playwright test",
    "test:performance": "npm run lighthouse && npm run bundlesize",
    "test:accessibility": "playwright test --grep accessibility",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "lighthouse": "lighthouse http://localhost:3000/designer --output=json --output-path=./lighthouse-results.json",
    "bundlesize": "bundlesize",
    "type-check": "tsc --noEmit"
  },
